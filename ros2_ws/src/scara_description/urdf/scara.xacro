<?xml version="1.0" encoding="utf-8"?>
<robot name="scara" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find scara_description)/urdf/gripper.xacro" />

  <link name="world"/>
  
  <joint name="fixed_base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.030725 0.000004 0.058678" rpy="0 0 0" />
      <mass value="0.685156" />
      <inertia ixx="0.000569" ixy="0.0" ixz="0.0" iyy="0.001012" iyz="0.0" izz="0.001168" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://scara_description/meshes/base_link.STL" /></geometry>
      <material name="base_mat"><color rgba="0.75 0.75 0.75 1" /></material>
    </visual>
    <collision>
      <geometry><mesh filename="package://scara_description/meshes/base_link.STL" /></geometry>
    </collision>
  </link>

  <link name="hand1">
    <inertial>
      <origin xyz="0.125 0.0 0.021" rpy="0 0 0" />
      <mass value="0.312571" />
      <inertia ixx="0.000208" ixy="0.0" ixz="0.0" iyy="0.002023" iyz="0.0" izz="0.002214" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://scara_description/meshes/hand1.STL" /></geometry>
      <material name="hand1_mat"><color rgba="0.56 0.56 0.56 1" /></material>
    </visual>
    <collision>
      <geometry><mesh filename="package://scara_description/meshes/hand1.STL" /></geometry>
    </collision>
  </link>

  <joint name="hand1_joint" type="revolute">
    <origin xyz="0 0 0.115" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="hand1" />
    <axis xyz="0 0 -1" />
    <dynamics damping="0.05" friction="0.0"/>
    <limit effort="1000.0" velocity="4.2" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="hand2">
    <inertial>
      <origin xyz="0.04043 0.000006 0.040401" rpy="0 0 0" />
      <mass value="0.442501" />
      <inertia ixx="0.000202" ixy="0.0" ixz="0.0" iyy="0.000741" iyz="0.0" izz="0.000892" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://scara_description/meshes/hand2.STL" /></geometry>
      <material name="hand2_mat"><color rgba="0.75 0.75 0.75 1" /></material>
    </visual>
    <collision>
      <geometry><mesh filename="package://scara_description/meshes/hand2.STL" /></geometry>
    </collision>
  </link>

  <joint name="hand2_joint" type="revolute">
    <origin xyz="0.25 0 0.039" rpy="0 0 0" />
    <parent link="hand1" />
    <child link="hand2" />
    <axis xyz="0 0 -1" />
    <dynamics damping="0.05" friction="0.0"/>
    <limit effort="1000.0" velocity="4.2" lower="-3.14" upper="3.14"/>
  </joint>

  <link name="hand3">
    <inertial>
      <origin xyz="0.000017 0.000004 0.041887" rpy="0 0 0" />
      <mass value="0.174476" />
      <inertia ixx="0.000110" ixy="0.0" ixz="0.0" iyy="0.000057" iyz="0.0" izz="0.000096" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://scara_description/meshes/hand3.STL" /></geometry>
      <material name="hand3_mat"><color rgba="0.56 0.56 0.56 1" /></material>
    </visual>
    <collision>
      <geometry><mesh filename="package://scara_description/meshes/hand3.STL" /></geometry>
    </collision>
  </link>

  <joint name="hand3_joint" type="prismatic">
    <origin xyz="0.2415 0 0.001" rpy="0 0 0" />
    <parent link="hand2" />
    <child link="hand3" />
    <axis xyz="0 0 -1" />
    <dynamics damping="20.0" friction="0.0"/>
    <limit effort="1000.0" velocity="0.63" lower="0.0" upper="0.11"/>
  </joint>

  <xacro:scara_gripper parent="hand3" />


  <ros2_control name="GazeboSimSystem" type="system">
      <hardware>
          <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>
  
      <joint name="hand1_joint">
          <command_interface name="position" /> 
          <state_interface name="position">
              <param name="initial_value">0.0</param>
          </state_interface>
          <state_interface name="velocity"/>
      </joint>
  
      <joint name="hand2_joint">
          <command_interface name="position" />
          <state_interface name="position">
               <param name="initial_value">0.0</param>
          </state_interface>
          <state_interface name="velocity"/>
      </joint>
  
      <joint name="hand3_joint">
          <command_interface name="position" />
          <state_interface name="position">
               <param name="initial_value">0.0</param>
          </state_interface>
          <state_interface name="velocity"/>
      </joint>
      <joint name="finger2_joint">
	<command_interface name="position" />
	<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
	<state_interface name="velocity"/>
      </joint>

	    <joint name="finger3_joint">
		<command_interface name="position" />
		<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
		<state_interface name="velocity"/>
	    </joint>

	    <joint name="finger4_joint">
		<command_interface name="position" />
		<state_interface name="position"><param name="initial_value">0.0</param></state_interface>
		<state_interface name="velocity"/>
	    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find scara_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
