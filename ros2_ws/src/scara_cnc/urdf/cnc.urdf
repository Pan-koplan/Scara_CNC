<?xml version="1.0"?>
<robot name="cnc_machine">
  <link name="cnc_body">
    <visual>
      <geometry>
        <box size="0.3 0.3 0.2"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.3 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  
  <gazebo reference="cnc_body">
    <material>Gazebo/Grey</material>
    <static>true</static> </gazebo>
</robot>
