<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <xacro:macro name="scara_gripper" params="parent">

    <joint name="gripper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="gripper_base_link"/>
      <origin xyz="0 0 0.0" rpy="0 0 0" /> 
    </joint>

    <link name="gripper_base_link">
      <inertial>
        <origin xyz="-0.00019026 -2.5665E-06 -0.045666" rpy="0 0 0" />
        <mass value="0.20624" />
        <inertia ixx="0.00020414" ixy="-4.0599E-09" ixz="-3.4991E-07" iyy="0.00020316" iyz="-1.2479E-08" izz="0.00028376" />
      </inertial>
      <visual>
        <origin xyz="-0.05 0.05 -0.07" rpy="1.5708 0 0" />
        <geometry>
          <mesh filename="model://scara_description/meshes/gripper_base.STL" />
        </geometry>
        <material name="dark_grey"><color rgba="0.10196 0.10196 0.10196 1" /></material>
      </visual>
      <collision>
        <origin xyz="-0.05 0.05 -0.05" rpy="1.5708 0 0" />
        <geometry>
          <mesh filename="model://scara_description/meshes/gripper_base.STL" />
        </geometry>
      </collision>
    </link>

    <link name="finger2">
      <inertial>
        <origin xyz="-0.015187 -0.02885 -0.027276" rpy="0 0 0" />
        <mass value="0.0039365" />
        <inertia ixx="8.4096E-07" ixy="-2.2855E-07" ixz="-1.8693E-07" iyy="5.271E-07" iyz="-3.5511E-07" izz="6.0988E-07" />
      </inertial>
      <visual>
        <geometry><mesh filename="model://scara_description/meshes/finger2.STL" /></geometry>
        <material name="white"><color rgba="1 1 1 1" /></material>
      </visual>
      <collision>
        <geometry><mesh filename="model://scara_description/meshes/finger2.STL" /></geometry>
      </collision>
    </link>
    <gazebo reference="finger2">
	  <mu1>100000.0</mu1>
	  <mu2>100000.0</mu2>
	  <kp>1000000.0</kp>
	  <kd>1.0</kd>
	  <minDepth>0.005</minDepth>
	  <maxVel>0.0</maxVel> <material>Gazebo/Grey</material>
	  <implicitSpringDamper>true</implicitSpringDamper>
    </gazebo>

    <joint name="finger2_joint" type="revolute">
      <origin xyz="-0.01665 -0.028839 -0.0755" rpy="0 0 0" />
      <parent link="gripper_base_link" />
      <child link="finger2" />
      <axis xyz="0 0 1" />
      <limit lower="-6.28" upper="6.28" effort="10" velocity="1" />
    </joint>

    <link name="finger3">
      <inertial>
        <origin xyz="0.032578 0.001279 -0.027275" rpy="0 0 0" />
        <mass value="0.003936" />
        <inertia ixx="4.07E-07" ixy="-2.17E-08" ixz="4.00E-07" iyy="9.60E-07" iyz="1.57E-08" izz="6.09E-07" />
      </inertial>
      <visual>
        <geometry><mesh filename="model://scara_description/meshes/finger3.STL" /></geometry>
        <material name="white"><color rgba="1 1 1 1" /></material>
      </visual>
      <collision>
        <geometry><mesh filename="model://scara_description/meshes/finger3.STL" /></geometry>
      </collision>
    </link>
        <gazebo reference="finger3">
	  <mu1>100000.0</mu1>
	  <mu2>100000.0</mu2>
	  <kp>1000000.0</kp>
	  <kd>1.0</kd>
	  <minDepth>0.005</minDepth>
	  <maxVel>0.0</maxVel> <material>Gazebo/Grey</material> 
	  <implicitSpringDamper>true</implicitSpringDamper>
    </gazebo>

    <joint name="finger3_joint" type="revolute">
      <origin xyz="0.0333 0 -0.0755" rpy="0 0 0" />
      <parent link="gripper_base_link" />
      <child link="finger3" />
      <axis xyz="0 0 1" />
      <limit lower="-6.28" upper="6.28" effort="10" velocity="1" />
    </joint>

    <link name="finger4">
      <inertial>
        <origin xyz="-0.009792 0.031098 -0.027276" rpy="0 0 0" />
        <mass value="0.003936" />
        <inertia ixx="9.11E-07" ixy="1.58E-07" ixz="-1.20E-07" iyy="4.56E-07" iyz="3.82E-07" izz="6.09E-07" />
      </inertial>
      <visual>
        <geometry><mesh filename="model://scara_description/meshes/finger4.STL" /></geometry>
        <material name="white"><color rgba="1 1 1 1" /></material>
      </visual>
      <collision>
        <geometry><mesh filename="model://scara_description/meshes/finger4.STL" /></geometry>
      </collision>
    </link>
    <gazebo reference="finger4">
	  <mu1>100000.0</mu1>
	  <mu2>100000.0</mu2>
	  <kp>1000000.0</kp>
	  <kd>1.0</kd>
	  <minDepth>0.005</minDepth>
	  <maxVel>0.0</maxVel> <material>Gazebo/Grey</material>
	  <implicitSpringDamper>true</implicitSpringDamper> 
    </gazebo>

    <joint name="finger4_joint" type="revolute">
      <origin xyz="-0.01665 0.028839 -0.0755" rpy="0 0 0" />
      <parent link="gripper_base_link" />
      <child link="finger4" />
      <axis xyz="0 0 1" />
      <limit lower="-6.28" upper="6.28" effort="10" velocity="1" />
    </joint>

  </xacro:macro>
</robot>
